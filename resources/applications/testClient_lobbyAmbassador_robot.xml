<application>
    <name>Test_MCP_CLIENT_LobbyAmbassador_robot</name>
    <dependencies>
    </dependencies>

    <!-- Applications -->
    <application>
        <name>Navigation_ROS2_R1SN003_cris_new_area_on_board</name>
        <prefix></prefix>
    </application>

    <application>
        <name>Speech_Pipeline_MCP_robot</name>
        <prefix></prefix>
    </application>


    <!-- Modules -->
    <module>
        <name>python3</name>
        <parameters>yarp_server_launcher.py --context test_servers --from test_lobbyAmbassador_robot.ini</parameters>
        <workdir>$ENV{ROBOT_CODE}/yarp-mcpServers</workdir>
        <node>console-mcp</node>
    </module>

    <module>
        <name>python3</name>
        <parameters>Yarp_mcpClient_GeneralPurpose.py --core checker --mode yarp --yarp-port /testClient/text:i</parameters>
        <workdir>$ENV{ROBOT_CODE}/yarp-mcpClient-generalPurpose</workdir>
        <node>console-mcp</node>
    </module>

    <!-- Connections -->

    <connection>
        <from>/speechTranscription_nws/text:o</from>
        <to>/testClient/text:i</to>
        <protocol>fast_tcp</protocol>
    </connection>

