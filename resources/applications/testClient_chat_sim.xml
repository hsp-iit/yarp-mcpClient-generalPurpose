<application>
    <name>Test_MCP_CLIENT_chat_sim</name>
    <dependencies>
    </dependencies>

    <!-- Applications -->
    <application>
        <name>Navigation_ROS2_R1Mk3_SIM_light</name>
        <prefix></prefix>
    </application>

    <!-- Modules -->

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context vadModule --from audioPlayer.ini</parameters>
        <node>console</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context speechPipeline --from azureSynthesizer.ini</parameters>
        <node>console</node>
    </module>

    <module>
        <name>yarpview</name>
        <parameters>--name /robot/faceDisplay/image:i</parameters>
        <node>console</node>
    </module>

    <module>
        <name>faceExpressionImage5GTour</name>
        <parameters></parameters>
        <node>console</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--from mcpFakeBattery.ini</parameters>
        <node>console</node>
    </module>

    <module>
        <name>python3</name>
        <parameters>yarp_server_launcher.py --context test_servers --from test_batteryNnavigationNSynth.ini</parameters>
        <workdir>$ENV{ROBOT_CODE}/yarp-mcpServers</workdir>
        <node>console-mcp</node>
    </module>

    <!-- Connections -->

    <connection>
        <from>/faceExpressionImage/image:o</from>
        <to>/robot/faceDisplay/image:i</to>
        <protocol>fast_tcp</protocol>
    </connection>

    <connection>
        <from>/audioPlayerWrapper/status:o</from>
        <to>/faceExpressionImage/mouthAudioData:i </to>
        <protocol>fast_tcp</protocol>
    </connection>

    <connection>
        <from>/speechSynthesizer_nws/sound:o</from>
        <to>/audioPlayerWrapper/audio:i</to>
        <protocol>fast_tcp</protocol>
    </connection>

</application>